{
  "name": "redisbox",
  "version": "0.0.1",
  "description": "Redis emulator",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project 'node:*'",
    "test:node:unit": "vitest run --project node:unit",
    "test:node:integration": "vitest run --project node:integration",
    "test:node:e2e": "vitest run --project node:e2e",
    "test:bun": "bun run vitest run --project 'bun:*'",
    "test:bun:unit": "bun run vitest run --project bun:unit",
    "test:bun:integration": "bun run vitest run --project bun:integration",
    "test:bun:e2e": "bun run vitest run --project bun:e2e",
    "test:deno": "deno run -A --node-modules-dir=auto npm:vitest run --project 'deno:*'",
    "test:deno:unit": "deno run -A --node-modules-dir=auto npm:vitest run --project deno:unit",
    "test:deno:integration": "deno run -A --node-modules-dir=auto npm:vitest run --project deno:integration",
    "test:deno:e2e": "deno run -A --node-modules-dir=auto npm:vitest run --project deno:e2e",
    "test:browser": "vitest run --project 'browser:*'",
    "test:browser:unit": "vitest run --project browser:unit",
    "test:browser:integration": "vitest run --project browser:integration",
    "test:browser:e2e": "vitest run --project browser:e2e"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "buffer": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.52.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18",
    "wasmoon-lua5.1": "^1.18.10"
  }
}
